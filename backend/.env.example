NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://localhost:27017/govinda-ai

JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_URL=http://localhost:3000

# AI provider selection
# - gemini (default): stable provider used for chat
# - openai: enables the OpenAI agent + tool calling (maps/calls/memory)
AI_PROVIDER=gemini

# OpenAI (primary AI agent with tool calling)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini (fallback when OPENAI_API_KEY is unset)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Google Maps (Places API, Geocoding API)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Exotel (healthcare calling)
# Use api.in.exotel.com (Mumbai) or api.exotel.com (Singapore) per your Exotel cluster
EXOTEL_API_BASE=https://api.in.exotel.com
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=
EXOTEL_EXOPHONE=
# Required for two-leg Connect: number Exotel calls FIRST (agent/staff). Then destination is To.
EXOTEL_FROM_NUMBER=
# Optional: terminal StatusCallback URL (must be publicly reachable by Exotel)
EXOTEL_STATUS_CALLBACK_URL=
# Optional: if set, webhook expects ?token= this value
EXOTEL_WEBHOOK_SECRET=

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=

# Anam (conversational avatars)
ANAM_API_KEY=
ANAM_AGENT_ID_GOVINDA=
ANAM_AGENT_ID_DURGA=

# Company outreach identity (Find Care — official sender, not staff personal)
COMPANY_WHATSAPP_NUMBER=+918287883300
COMPANY_SUPPORT_EMAIL=xpertnoteanalytics@gmail.com

# Email outreach (Find Care)
# Provider: log (dev, logs only), resend, sendgrid
# Outbound From uses COMPANY_SUPPORT_EMAIL (falls back to EMAIL_FROM)
EMAIL_PROVIDER=log
EMAIL_FROM=operations@yourdomain.com
RESEND_API_KEY=
SENDGRID_API_KEY=

# WhatsApp outreach
# Provider: log (dev), twilio, meta
# API sends FROM COMPANY_WHATSAPP_NUMBER (or TWILIO_WHATSAPP_FROM if set)
WHATSAPP_PROVIDER=log
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
